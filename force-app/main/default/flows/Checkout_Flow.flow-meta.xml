    <formulas>
        <name>Button_Display_Text</name>
        <dataType>String</dataType>
        <expression>$Label.ec_pay_button_prefix + " " + CASE({!currency}, &apos;EUR&apos;, &apos;€&apos;, &apos;USD&apos;, &apos;$&apos;, &apos;GBP&apos;, &apos;£&apos;, {!currency} + &apos; &apos;) + TEXT({!amount})</expression>
    </formulas>
    <formulas>
        <name>Frequency_Display_Text</name>
        <dataType>String</dataType>
        <expression>if({!frequency}=&apos;oneTime&apos;, $Label.ec_frequency_label_one_time, $Label.ec_frequency_label_monthly)</expression>
    </formulas>
    <formulas>
        <name>Frequency_Display_Text_Existing</name>
        <dataType>String</dataType>
        <expression>IF(ISNULL({!Get_Recurring_Payment.Id}), $Label.ec_frequency_label_one_time, INITCAP(TEXT({!Get_Recurring_Payment.cpm__Frequency__c})))</expression>
    </formulas>
    <formulas>
        <name>Is_Current_User_Sys_Admin</name>
        <dataType>Boolean</dataType>
        <expression>{!$Profile.Name} = &apos;System Administrator&apos;</expression>
    </formulas>
    <formulas>
        <name>One_Time_Amount</name>
        <dataType>Currency</dataType>
        <expression>IF({!frequency} = &apos;oneTime&apos;, {!amount}, null)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>Recurring_Amount</name>
        <dataType>Currency</dataType>
        <expression>IF({!frequency} = &apos;recurring&apos;, {!amount}, null)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>Reference_Existing</name>
        <dataType>String</dataType>
        <expression>IF(!ISBLANK({!Get_Installment.cpm__Final_Payment_Reference__c}),{!Get_Installment.cpm__Final_Payment_Reference__c}, {!Get_Recurring_Payment.cpm__Final_Payment_Reference__c})</expression>
