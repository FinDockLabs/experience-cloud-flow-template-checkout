    <decisions>
        <description>The flow can either use an existing installment and pay that, or insert a new installment based on record data.</description>
        <name>Pay_Existing_Record</name>
        <label>Existing or new record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Assign_example_variables</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>New record</defaultConnectorLabel>
        <rules>
            <name>Existing_record</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>id</leftValueReference>
